# =====================================================
# 🔥 DATABASE
# =====================================================
MONGO_URI=mongodb+srv://noma:1234@cluster0.rrqqvu.mongodb.net/mazzang?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI_DEV=mongodb://127.0.0.1:27017/mazzang_dev
MONGO_URI_PROD=mongodb+srv://noma:1234@cluster0.rrqqvu.mongodb.net/mazzang_prod?retryWrites=true&w=majority&appName=Cluster0

# Redis (🔥 추가)
REDIS_URL=redis://127.0.0.1:6379

# =====================================================
# 🔥 AUTH (강화)
# =====================================================
JWT_SECRET=dev_super_secret_key_1234567890_abcdefghijklmnopqrstuvwxyz
JWT_EXPIRES=7d

JWT_REFRESH_SECRET=dev_refresh_secret_key_abcdefghijklmnopqrstuvwxyz_123456
JWT_REFRESH_EXPIRES=30d

JWT_ISSUER=NOMA
JWT_AUDIENCE=NOMA_USERS

# =====================================================
# 🔥 OAUTH (KAKAO)
# =====================================================
KAKAO_CLIENT_ID=dev_kakao_key
KAKAO_REDIRECT_URI=http://localhost:10000/auth/kakao/callback
KAKAO_TIMEOUT=5000
ADMIN_KAKAO_ID=

# =====================================================
# 🔥 PAYMENT
# =====================================================
PAYMENT_PROVIDER=toss
TOSS_SECRET_KEY=dev_toss_secret
TOSS_CLIENT_KEY=dev_toss_client
PAYMENT_TIMEOUT=10000
PAYMENT_CURRENCY=KRW

# =====================================================
# 🔥 APP CORE
# =====================================================
PORT=10000
NODE_ENV=development
LOG_LEVEL=debug
TZ=Asia/Seoul
SERVER_NAME=NOMA-SERVER
APP_VERSION=1.0.0

# =====================================================
# 🔥 FRONTEND
# =====================================================
APP_BASE_URL=http://localhost:3000
SOCKET_URL=http://localhost:3000
KAKAO_JS_KEY=dev_key
CDN_URL=

# =====================================================
# 🔥 UPLOAD
# =====================================================
MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads
UPLOAD_PRIVATE=false

# =====================================================
# 🔥 CORS
# =====================================================
CORS_ORIGIN_LIST=http://localhost:3000
CORS_CREDENTIALS=true

# =====================================================
# 🔥 SECURITY
# =====================================================
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=900000

ADMIN_IP=
FORCE_HTTPS=false
SECURE_COOKIE=false
TRUST_PROXY=false

ENABLE_HELMET=true
ENABLE_RATE_LIMIT=true
ENABLE_REQUEST_LOG=true

# =====================================================
# 🔥 FEATURE TOGGLE
# =====================================================
FEATURE_ROULETTE=true
FEATURE_ATTEND=true
FEATURE_REVIEW=true
FEATURE_ADMIN_DASHBOARD=true
FEATURE_REALTIME=true

# =====================================================
# 🔥 NOTIFICATION
# =====================================================
KAKAO_WEBHOOK=
SLACK_WEBHOOK=
DISCORD_WEBHOOK=
EMAIL_ALERT=true
ADMIN_EMAIL=admin@noma.local

# =====================================================
# 🔥 LOGGING / MONITORING
# =====================================================
LOG_FILE=true
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m

# =====================================================
# 🔥 DEBUG
# =====================================================
DEBUG=true
DEBUG_API=true
DEBUG_DB=true
DEBUG_SOCKET=false

# =====================================================
# 🔥 NGINX / PROXY
# =====================================================
PROXY_TRUST=false
REAL_IP_HEADER=X-Forwarded-For

# =====================================================
# 🔥 PERFORMANCE
# =====================================================
CLUSTER_MODE=false
MAX_WORKERS=4

# =====================================================
# 🔥 FAILSAFE / RECOVERY
# =====================================================
AUTO_RESTART=true
GRACEFUL_SHUTDOWN=true
SHUTDOWN_TIMEOUT=5000