function createLocalAdminToken(id) {
  return jwt.sign(
    {
      id,
      _id: `local-${id}`,
      role: "admin",
      isAdmin: true,
      type: "admin",
      userRole: "admin",
      localFallback: true,
    },
    JWT_SECRET,
    {
      expiresIn: process.env.JWT_EXPIRES_IN || "7d",
    }
  );
}

