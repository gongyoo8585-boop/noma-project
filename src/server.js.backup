  }

  console.warn(warning);
});

async function withStartupTimeout(promise, ms, label) {
  let timer;

  try {
    return await Promise.race([
      promise,
      new Promise((resolve) => {
        timer = setTimeout(() => {
          console.warn(`⚠️ ${label} TIMEOUT AFTER ${ms}ms`);
          resolve(false);
        }, ms);
      }),
    ]);
  } finally {
    if (timer) {
      clearTimeout(timer);
    }
  }
}

