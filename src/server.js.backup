function maskMongoUri(uri) {
  if (!uri) return "";

  return String(uri).replace(
    /(mongodb(?:\+srv)?:\/\/)([^:@/]+):([^@/]+)@/i,
    "$1$2:****@"
  );
}

function getMongoUri() {
  return (
    process.env.MONGO_URI ||
    process.env.MONGODB_URI ||
    process.env.DATABASE_URL ||
    process.env.DB_URI ||
    ""
  );
}

