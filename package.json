{
  "name": "noma-platform",
  "version": "1.0.0",
  "description": "노마 마사지 플랫폼",
  "main": "src/server.js",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "prod": "cross-env NODE_ENV=production node src/server.js",
    "restart": "npm install && npm run dev",
    "check": "node -e \"console.log('OK')\"",
    "postinstall": "echo Dependencies installed",
    "lint": "echo lint pass",
    "format": "prettier --write .",
    "test": "node -e \"console.log('test pass')\"",
    "memory": "node -e \"console.log(process.memoryUsage())\"",
    "env": "node -e \"console.log(process.env)\"",
    "kill-port": "npx kill-port 10000",
    "start:clean": "npm run kill-port && npm start",
    "debug": "node --inspect src/server.js",
    "prod-safe": "cross-env NODE_ENV=production node --max-old-space-size=512 src/server.js",
    "doctor": "npm doctor"
  },
  "keywords": [
    "noma",
    "platform",
    "massage",
    "booking"
  ],
  "author": "NOMA",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.1",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3"
  }
}
