{
  "name": "noma-platform",
  "version": "1.0.0",
  "description": "노마 마사지 플랫폼",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "restart": "npm install && npm run dev",
    "check": "node -e \"console.log('OK')\"",
    "postinstall": "echo Dependencies installed",
    "seed": "node scripts/seed.js",
    "prod": "cross-env NODE_ENV=production node server.js",
    "lint": "echo lint pass",
    "clean": "rimraf node_modules",
    "reinstall": "npm run clean && npm install",
    "logs": "node -e \"console.log('logs')\"",
    "health": "node -e \"console.log('health ok')\"",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "analyze": "node -e \"console.log('analyze ok')\"",
    "build": "echo build step",
    "test": "node -e \"console.log('test pass')\"",
    "db": "mongod",
    "db:docker": "docker start mongo || docker run -d -p 27017:27017 --name mongo mongo",
    "setup": "npm install && npm run seed",
    "dev:full": "concurrently \"npm run db\" \"npm run dev\"",
    "serve": "node server.js",
    "start:3000": "cross-env PORT=3000 node server.js",
    "memory": "node -e \"console.log(process.memoryUsage())\"",
    "ps": "node -e \"console.log(process.pid)\"",
    "env": "node -e \"console.log(process.env)\"",
    "reset": "npm run clean && npm install && npm run seed",
    "kill-port": "npx kill-port 10000",
    "start:clean": "npm run kill-port && npm start",
    "logs:dev": "nodemon server.js",
    "quick": "node server.js",
    "check:port": "netstat -ano | findstr :10000",
    "dev-fast": "nodemon --watch server.js server.js",
    "debug": "node --inspect server.js",
    "prod-safe": "cross-env NODE_ENV=production node --max-old-space-size=512 server.js",
    "clear-cache": "npm cache clean --force",
    "install-clean": "rimraf node_modules package-lock.json && npm install",
    "port-random": "cross-env PORT=0 node server.js",
    "analyze-deps": "npm ls --depth=0",
    "fix": "npm audit fix",
    "force-fix": "npm audit fix --force",
    "doctor": "npm doctor"
  },
  "keywords": [
    "noma",
    "platform",
    "massage",
    "booking",
    "map",
    "reservation"
  ],
  "author": "NOMA",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.3.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "helmet-csp": "^3.4.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.6.12",
    "rate-limit-redis": "^4.2.0",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5"
  }
}
