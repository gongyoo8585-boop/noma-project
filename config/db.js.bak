"use strict";

const database = require("./database");

/* =====================================================
🔥 기존 API 유지
===================================================== */

async function connectDB() {
  if (typeof database.connectDB === "function") {
    return database.connectDB();
  }

  if (typeof database.connect === "function") {
    return database.connect();
  }

  return null;
}

async function closeDB() {
  if (typeof database.closeDB === "function") {
    return database.closeDB();
  }

  if (typeof database.close === "function") {
    return database.close();
  }

  return null;
}

function isDBConnected() {
  if (typeof database.isDBConnected === "function") {
    return database.isDBConnected();
  }

  return false;
}

function getDBStatus() {
  if (typeof database.getDBStatus === "function") {
    return database.getDBStatus();
  }

  return "unknown";
}

/* =====================================================
🔥 EXPORT
===================================================== */

module.exports = {
  connectDB,
  closeDB,
  isDBConnected,
  getDBStatus
};
