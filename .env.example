# =========================
# 🔥 기존 환경변수 유지
# =========================
PORT=10000
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/noma?retryWrites=true&w=majority
JWT_SECRET=change_me
NODE_ENV=development

# 카카오 로그인/지도 확장용
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=
KAKAO_JS_KEY=

# 알림 확장용
KAKAO_WEBHOOK=
ADMIN_EMAIL=admin@noma.local


# =========================
# 🔥 추가 위치 1: 개발/운영 분리
# =========================
MONGO_URI_DEV=mongodb://127.0.0.1:27017/noma_dev
MONGO_URI_PROD=mongodb+srv://username:password@cluster0.prod.mongodb.net/noma

# =========================
# 🔥 추가 위치 2: 보안 강화
# =========================
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# 🔥 추가 위치 3: 서버 설정
# =========================
APP_BASE_URL=http://localhost:10000
CORS_ORIGIN=*
MAX_FILE_SIZE_MB=5

# =========================
# 🔥 추가 위치 4: 로그 시스템
# =========================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# =========================
# 🔥 추가 위치 5: Redis (RateLimit 확장)
# =========================
REDIS_URL=redis://127.0.0.1:6379

# =========================
# 🔥 추가 위치 6: 이메일 설정
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =========================
# 🔥 추가 위치 7: 외부 API
# =========================
AXIOS_TIMEOUT=5000
API_RETRY_COUNT=3

# =========================
# 🔥 추가 위치 8: 스케줄러 (cron)
# =========================
CRON_CLEAN_INTERVAL=*/10 * * * *
CRON_STATS_INTERVAL=0 * * * *

# =========================
# 🔥 추가 위치 9: 업로드 경로
# =========================
UPLOAD_DIR=uploads
STATIC_DIR=public

# =========================
# 🔥 추가 위치 🔟: 디버그/개발 옵션
# =========================
ENABLE_DEBUG=true
MOCK_MODE=false